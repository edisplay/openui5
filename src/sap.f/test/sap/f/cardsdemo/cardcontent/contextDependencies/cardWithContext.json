{
	"sap.app": {
		"id": "sap.f.cardsdemo.cardcontent.contextDependencies.cardWithContext",
		"type": "card"
	},
	"sap.card": {
		"type": "List",
		"configuration": {
			"parameters": {
				"userId": {
					"value": "{context>/sample/currentUser/id}"
				},
				"userName": {
					"value": "{context>/sample/currentUser/name}"
				}
			}
		},
		"header": {
			"title": "Tasks for {parameters>/userName/value}",
			"subtitle": "User ID: {parameters>/userId/value}",
			"icon": {
				"src": "sap-icon://person-placeholder"
			}
		},
		"content": {
			"data": {
				"json": [
					{"title": "Approve purchase order", "description": "PO #12345"},
					{"title": "Review budget report", "description": "Q2 2026"},
					{"title": "Update team allocation", "description": "Sprint 14"}
				]
			},
			"item": {
				"title": "{title}",
				"description": "{description}"
			}
		}
	}
}
