{
	"sap.app": {
		"id": "sap.f.cardsdemo.cardcontent.contextDependencies.cardWithoutContext",
		"type": "card"
	},
	"sap.card": {
		"type": "List",
		"header": {
			"title": "Company Announcements",
			"subtitle": "Latest news",
			"icon": {
				"src": "sap-icon://newspaper"
			}
		},
		"content": {
			"data": {
				"json": [
					{"title": "Office closed on Friday", "description": "July 18, 2026"},
					{"title": "New cafeteria menu available", "description": "Starting next week"},
					{"title": "Parking lot maintenance", "description": "July 20-21"}
				]
			},
			"item": {
				"title": "{title}",
				"description": "{description}"
			}
		}
	}
}
