{
	"sap.app": {
		"id": "test.card.customSettingsSDKOnly",
		"type": "card"
	},
	"sap.card": {
		"type": "List",
		"header": {
			"title": "SDK Settings Only Test",
			"subtitle": "No manifest customSettings - all from SDK",
			"visible": "{= ${customSettings>/showHeader} !== false}"
		},
		"content": {
			"data": {
				"json": [
					{
						"Name": "Feature 1",
						"Status": "{= ${customSettings>/feature1} ? 'Enabled' : 'Disabled'}"
					},
					{
						"Name": "Feature 2",
						"Status": "{= ${customSettings>/feature2} ? 'Enabled' : 'Disabled'}"
					},
					{
						"Name": "Preview Mode",
						"Status": "{= ${customSettings>/isPreview} ? 'Active' : 'Inactive'}"
					}
				]
			},
			"item": {
				"title": {
					"value": "{Name}"
				},
				"description": {
					"value": "{Status}"
				}
			}
		}
	}
}
