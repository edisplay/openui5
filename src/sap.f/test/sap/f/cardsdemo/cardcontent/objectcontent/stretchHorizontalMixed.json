{
	"sap.app": {
		"id": "cardsdemo.object.stretchHorizontalMixed",
		"type": "card",
		"i18n": "i18n/i18n.properties"
	},
	"sap.card": {
		"type": "Object",
		"data": {
			"request": {
				"url": "./employee.json"
			}
		},
		"header": {
			"icon": {
				"src": "{photo}"
			},
			"title": "{firstName} {lastName}",
			"subtitle": "Stretch / Horizontal — Mixed content"
		},
		"content": {
			"groups": [
				{
					"title": "Mixed group",
					"alignment": "Stretch",
					"itemsLayout": "Horizontal",
					"items": [
						{
							"label": "Phone",
							"value": "{phone}"
						},
						{
							"label": "Status",
							"value": "Active",
							"type": "Status",
							"state": "Success"
						},
						{
							"label": "Manager",
							"value": "{manager/firstName} {manager/lastName}",
							"icon": {
								"src": "{manager/photo}"
							}
						},
						{
							"label": "Rating",
							"type": "RatingIndicator",
							"maxValue": 5,
							"value": 3.5
						},
						{
							"label": "Years",
							"type": "NumericData",
							"mainIndicator": {
								"number": "12",
								"trend": "Up",
								"state": "Good"
							}
						},
						{
							"label": "Website",
							"value": "{company/website}"
						}
					]
				},
				{
					"title": "Default group below (vertical)",
					"items": [
						{
							"label": "Address",
							"value": "{company/address}"
						},
						{
							"label": "Company",
							"value": "{company/name}"
						}
					]
				}
			]
		}
	}
}
