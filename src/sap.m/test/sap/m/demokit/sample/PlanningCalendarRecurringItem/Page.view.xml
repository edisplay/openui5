<mvc:View
	controllerName="sap.m.sample.PlanningCalendarRecurringItem.Page"
	xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:unified="sap.ui.unified"
	xmlns="sap.m">
	<VBox class="sapUiSmallMargin">
		<PlanningCalendar
			id="PC1"
			startDate="{path: '/startDate'}"
			rows="{path: '/people'}"
			appointmentsVisualization="Filled"
			rowHeaderPress=".handleRowHeaderPress"
			showEmptyIntervalHeaders="false"
			builtInViews="Hour,Day,Week,Month,One Month"
			viewKey="{/viewKey}"
			showWeekNumbers="true">
			<toolbarContent>
				<Title text="Recurring Appointments" titleStyle="H4"/>
				<ToolbarSpacer />
				<Button text="Create Appointment" type="Emphasized" press=".onCreateAppointment" />
			</toolbarContent>
			<rows>
				<PlanningCalendarRow
					icon="{pic}"
					title="{name}"
					text="{role}"
					enableAppointmentsCreate="true"
					enableAppointmentsDragAndDrop="true"
					appointments="{path: 'appointments', templateShareable: false}"
					intervalHeaders="{path: 'headers', templateShareable: false}"
					nonWorkingPeriods="{path : 'nonWorkingPeriods', templateShareable: false}"
					appointmentCreate=".onAppointmentCreate"
					appointmentDrop=".onAppointmentDrop">
					<customData>
						<core:CustomData key="emp-name" value="{name}" writeToDom="true"/>
					</customData>
					<appointments>
						<unified:RecurringCalendarAppointment
							startDate="{startDate}"
							endDate="{endDate}"
							recurrenceType="{recurrenceType}"
							recurrencePattern="{recurrencePattern}"
							recurrenceEndDate="{recurrenceEndDate}"
							title="{title}"
							type="{type}">
						<unified:recurrenceRule>
							<unified:RecurrenceRule
								days="{recurrenceDay}"
								type="{ruleType}"
								dayOfMonth="{ruleDayOfMonth}"
								weekOfMonth="{ruleWeekOfMonth}"
								dayOfWeek="{ruleDayOfWeek}"
								month="{ruleMonth}" />
						</unified:recurrenceRule>
					</unified:RecurringCalendarAppointment>
					</appointments>
					<nonWorkingPeriods>
						<unified:RecurringNonWorkingPeriod
							recurrenceType= "{recurrenceType}"
							recurrenceEndDate= "{recurrenceEndDate}"
							recurrencePattern= "{recurrencePattern}"
							date="{date}">
							<unified:TimeRange
								start="{start}"
								end="{end}"
								valueFormat="{valueFormat}"
							/>
						</unified:RecurringNonWorkingPeriod>
					</nonWorkingPeriods>
					<intervalHeaders>
						<unified:CalendarAppointment
							startDate="{start}"
							endDate="{end}"
							icon="{pic}"
							title="{title}"
							type="{type}">
						</unified:CalendarAppointment>
					</intervalHeaders>
				</PlanningCalendarRow>
			</rows>
		</PlanningCalendar>
	</VBox>
</mvc:View>
