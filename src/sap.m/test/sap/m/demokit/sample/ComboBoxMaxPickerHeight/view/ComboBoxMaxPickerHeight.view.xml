<mvc:View
	height="100%"
	controllerName="sap.m.sample.ComboBoxMaxPickerHeight.controller.ComboBoxMaxPickerHeight"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m">
	<Page showHeader="false" class="sapUiContentPadding">
		<content>
			<l:VerticalLayout>
				<Label text="ComboBox without maxPickerHeight" labelFor="idComboBoxDefault"></Label>
				<ComboBox class="sapUiSmallMarginBottom"
					id="idComboBoxDefault"
					items="{
						path: '/items'
					}">
					<core:Item key="{key}" text="{text}"/>
				</ComboBox>

				<Label text="ComboBox with maxPickerHeight='300px'" labelFor="idComboBox300px"></Label>
				<ComboBox class="sapUiSmallMarginBottom"
					id="idComboBox300px"
					maxPickerHeight="300px"
					items="{
						path: '/items'
					}">
					<core:Item key="{key}" text="{text}"/>
				</ComboBox>

				<Label text="ComboBox with maxPickerHeight='15rem'" labelFor="idComboBox15rem"></Label>
				<ComboBox class="sapUiSmallMarginBottom"
					id="idComboBox15rem"
					maxPickerHeight="15rem"
					items="{
						path: '/items'
					}">
					<core:Item key="{key}" text="{text}"/>
				</ComboBox>

				<Label text="ComboBox with maxPickerHeight='150px' and value state" labelFor="idComboBoxWithValueState"></Label>
				<ComboBox class="sapUiSmallMarginBottom"
					id="idComboBoxWithValueState"
					maxPickerHeight="150px"
					valueState="Information"
					valueStateText="The maxPickerHeight property limits the picker popup height. When items exceed this height, the picker becomes scrollable."
					items="{
						path: '/items'
					}">
					<core:Item key="{key}" text="{text}"/>
				</ComboBox>
			</l:VerticalLayout>
		</content>
	</Page>
</mvc:View>
