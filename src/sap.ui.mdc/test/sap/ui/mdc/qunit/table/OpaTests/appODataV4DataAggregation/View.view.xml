<mvc:View
	xmlns:mdc="sap.ui.mdc"
    xmlns:mdcTable="sap.ui.mdc.table"
    xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:variants="sap.ui.fl.variants"
	controllerName="sap.ui.mdc.table.OpaTests.appODataV4DataAggregation.Controller">
    <App>
        <Page showHeader="false">
            <Button text="Start RTA" press=".onPressRTA"/>
            <mdc:FilterBar
                id="mdcFilterBar"
                delegate="{
                    name: 'delegates/odata/v4/FilterBarDelegate',
                    payload: {collectionName: 'BusinessPartners'}
                }">
                <mdc:basicSearchField>
                    <mdc:FilterField id="searchField" placeholder="Search" conditions="{$filters>/conditions/$search}" propertyKey="$search"/>
                </mdc:basicSearchField>
            </mdc:FilterBar>
            <mdc:Table
                id="mdcTable"
                header="Products"
                delegate="{
                    name: 'sap/ui/mdc/table/OpaTests/appODataV4DataAggregation/TableDelegate',
                    payload: {collectionName: 'BusinessPartners'}
                }"
                filter="mdcFilterBar"
                p13nMode="Column,Sort,Filter,Group,Aggregate"
                selectionMode="Multi"
                threshold="0"
                showRowCount="false"
                propertyKeys="Country,Region,Segment,SalesAmountLocalCurrency,SalesNumber,AccountResponsible"
                groupConditions="{
                    groupLevels: [
                        {name: 'Country_Code'},
                        {name: 'Region'},
                        {name: 'Segment'}
                    ]
                }"
                aggregateConditions="{
                    SalesAmountLocalCurrency: {}
                }">
                <mdc:type>
                    <mdcTable:GridTableType rowCountMode="Fixed" rowCount="5" />
                </mdc:type>
                <mdc:variant>
                    <variants:VariantManagement id="mdcTable-vm" for="mdcTable"/>
                </mdc:variant>
            </mdc:Table>
        </Page>
    </App>
</mvc:View>