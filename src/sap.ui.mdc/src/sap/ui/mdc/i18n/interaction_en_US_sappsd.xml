<?xml version="1.0" encoding="UTF8"?>
<interaction-documentation library="sap.ui.comp" xmlns="http://schemas.sap.com/sapui5/extension/sap.ui.core.InteractionDocumentation/1">
	<control-interactions>
		<control name="sap.ui.mdc.Table"/>
		<interaction>[[[ <kbd>Ctrl + ,</kbd> ]]]<description>
				<p>[[[ЕҺПҒД“ЕӢЕҹ ЕЈДҘД“ <span class="uicontrol">ЕўД…ЖғДәД“ ЕңД“ЕЈЕЈДҜЕӢДҹЕҹ</span> ЖҢДҜД…ДәЕҸДҹ, ДҜЖ’ Д…КӢД…ДҜДәД…ЖғДәД“.]]]</p>
			</description>
		</interaction>
		<interaction>[[[ <kbd>Ctrl + Shift + E</kbd> ]]]<description>
				<p>[[[ЕҺПҒД“ЕӢЕҹ ЕЈДҘД“ <span class="uicontrol">Д”ПҮПҒЕҸЕ—ЕЈ ДҖЕҹ</span> ЖҢДҜД…ДәЕҸДҹ ЕҸЖ’ ЕЈДҘД“ ЕЈД…ЖғДәД“, ДҜЖ’ Д…КӢД…ДҜДәД…ЖғДәД“.]]]</p>
			</description>
		</interaction>
	</control-interactions>
	<control-interactions>
		<control name="sap.ui.mdc.FilterBar"/>
		<interaction>[[[ <kbd>Enter</kbd> ]]]<description>
				<p>[[[ЕўЕ—ДҜДҹДҹД“Е—Еҹ ЕҹД“Д…Е—ДӢДҘ Ж’ЕҸЕ— Ж’ДҜДәЕЈД“Е— ЖғД…Е—.вҲҷвҲҷвҲҷвҲҷвҲҷвҲҷвҲҷвҲҷвҲҷвҲҷ]]]</p>
			</description>
		</interaction>
	</control-interactions>
	<control-interactions>
		<control name="sap.ui.mdc.Chart"/>
		<interaction>[[[ <kbd>Ctrl + ,</kbd> ]]]<description>
				<p>[[[ЕҺПҒД“ЕӢЕҹ ЕЈДҘД“ <span class="uicontrol">ЖІДҜД“Еө ЕңД“ЕЈЕЈДҜЕӢДҹЕҹ</span> ЖҢДҜД…ДәЕҸДҹ.]]]</p>
			</description>
		</interaction>
		<interaction>[[[ <kbd>Ctrl + D</kbd> ]]]<description>
				<p>[[[ДҺД“ДәД“ЕЈД“Еҹ Д…ЕӢ ДҜЕЈД“Йұ ДҜЕӢ ЕЈДҘД“ <span class="uicontrol">ЖІДҜД“Еө ЕңД“ЕЈЕЈДҜЕӢДҹЕҹ</span> ЖҢДҜД…ДәЕҸДҹ.]]]</p>
			</description>
		</interaction>
	</control-interactions>
</interaction-documentation>