# see http://editorconfig.org

root = true

[*]
charset = utf-8

[*.{html,java,js,json,txt}]
trim_trailing_whitespace = true
end_of_line = lf
tab_width = 4

[*.{css,less}]
trim_trailing_whitespace = true
end_of_line = lf
tab_width = 4
indent_style = tab
indent_size = 4
insert_final_newline = false

[pom.xml]
trim_trailing_whitespace = true
end_of_line = lf

# npm is using 2 spaces when modifying package.json
[package.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
